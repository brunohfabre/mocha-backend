// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String  @id @default(uuid())
  firstName String
  lastName  String
  email     String  @unique
  password  String
  phone     String  @unique
  githubId  String? @unique

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Project {
  id    String @id @default(uuid())
  title String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  connections Connection[]
  notes       Note[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

enum ConnectionType {
  POSTGRES
  MYSQL
  MARIADB
}

model Connection {
  id       String         @id @default(uuid())
  name     String
  host     String
  port     Int
  user     String
  password String
  type     ConnectionType

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Note {
  id      String @id @default(uuid())
  title   String
  content String

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}
