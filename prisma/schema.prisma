// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String  @id @default(uuid())
  first_name String
  last_name  String
  email      String  @unique
  password   String
  phone      String  @unique
  github_id  String? @unique

  projects Project[]
  contacts Contact[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("users")
}

model Invite {
  id       String  @id @default(uuid())
  from_id  String
  to_id    String
  accepted Boolean @default(false)

  created_at DateTime @default(now())

  @@map("invites")
}

model Contact {
  id String @id @default(uuid())

  user_id String

  contact_id String
  contact    User   @relation(fields: [contact_id], references: [id])

  created_at DateTime @default(now())

  @@map("contacts")
}

model Project {
  id         String  @id @default(uuid())
  title      String
  is_default Boolean @default(false)

  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  connections Connection[]
  notes       Note[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("projects")
}

enum ConnectionType {
  POSTGRES
  MYSQL
  MARIADB
}

model Connection {
  id       String         @id @default(uuid())
  name     String
  host     String
  port     Int
  user     String
  password String
  type     ConnectionType

  project_id String
  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("connections")
}

model Note {
  id      String @id @default(uuid())
  title   String
  content String

  project_id String
  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("notes")
}
