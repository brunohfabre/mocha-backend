// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String    @id @default(uuid())
  first_name String
  last_name  String
  email      String    @unique
  password   String
  phone      String    @unique
  github_id  String?   @unique

  projects   Project[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("users")
}

model Project {
  id          String       @id @default(uuid())
  title       String

  user_id     String
  user        User         @relation(fields: [user_id], references: [id])

  connections Connection[]
  notes       Note[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("projects")
}

enum ConnectionType {
  POSTGRES
  MYSQL
  MARIADB
}

model Connection {
  id       String         @id @default(uuid())
  name     String
  host     String
  port     Int
  user     String
  password String
  type     ConnectionType

  project_id String
  project    Project @relation(fields: [project_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("connections")
}

model Note {
  id         String  @id @default(uuid())
  title      String
  content    String

  project_id String
  project    Project @relation(fields: [project_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("notes")
}
